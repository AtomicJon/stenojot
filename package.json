{
  "name": "stenojot",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run && cargo test --manifest-path src-tauri/Cargo.toml",
    "test:ui": "vitest run",
    "test:ui:watch": "vitest",
    "test:tauri": "cargo test --manifest-path src-tauri/Cargo.toml",
    "release": "node scripts/release.mjs",
    "format": "prettier --write 'src/**/*.{ts,tsx,scss}' '*.json'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,scss}' '*.json'",
    "format:tauri": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "format:tauri:check": "cargo fmt --manifest-path src-tauri/Cargo.toml --check",
    "format:all": "yarn format && yarn format:tauri",
    "format:all:check": "yarn format:check && yarn format:tauri:check",
    "lint": "eslint . && tsc --noEmit",
    "lint:tauri": "cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
    "lint:all": "yarn lint && yarn lint:tauri",
    "ci": "yarn format:all:check && yarn lint:all && yarn test"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.13.1",
    "sass": "^1.98.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^7.0.4",
    "vitest": "^3"
  }
}
